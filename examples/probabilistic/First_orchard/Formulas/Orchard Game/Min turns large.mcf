% Minimum expected number of turns for the large version.
% Generic: 40.123403154579641239
% optimal: 40.123403154579641239
% worst: 44.382734671948838923

% minimal
form mu X.
    val(0) ||
    (
        [victory || defeat] val(0) &&
        [exists d: DiceVal . dice_roll(d)] (X + val(1)) &&
        [exists f1, f2: Fruit . pick_two(f1, f2)] X
    );
