% Max win probability parameterised by initial raven count K.

map K: Nat;
eqn K = 5;

form mu X(k: Nat = K).
    val(0) || 
    <victory>val(1) ||
    (val(if(k > 0, 1, 0)) * (
        <dice_roll(val_raven)>X(Int2Nat(k - 1)) ||
        (sup f: Fruit . <dice_roll(fruit(f))>X(k)) ||
        <dice_roll(basket)> (sup f1, f2: Fruit . <pick_two(f1, f2)>X(k))
    ))
;