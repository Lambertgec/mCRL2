% Minimum expected number of turns for the modified version.
% 20.88278653 - matching the first orchard version as expected 

% minimal
form mu X.
    val(0) ||
    (
        [victory || defeat] val(0) &&
        [exists d: DiceVal . dice_roll(d)] (X + val(1)) &&
        [exists f: Fruit . pick_two(f)] X && [exists r: Fruit . reduce(r)] (X + val(1))
    );
