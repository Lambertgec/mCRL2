% Maximum expected number of turns for the large version
% Generic: 44.382734671948838923
% optimal: 40.123403154579641239
% worst: 44.382734671948838923

% max
form mu X.
    <victory || defeat> val(0) ||
    (sup d: DiceVal . <dice_roll(d)> (X + val(1))) ||
    (sup f1, f2: Fruit . <pick_two(f1, f2)> X) ||
    val(0);
